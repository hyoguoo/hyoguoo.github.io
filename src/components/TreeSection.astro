---
interface Props {
  label: string;
  labelVariant?: 'accent' | 'muted';
  hue?: number;
}
const { label, labelVariant = 'muted', hue } = Astro.props;
---

<div class="tree-section" style={hue !== undefined ? `--section-hue: ${hue}` : undefined}>
  <h2 class:list={['section-label', { 'section-label--accent': labelVariant === 'accent', 'section-label--colored': hue !== undefined }]}>
    {label}
  </h2>
  <slot />
</div>

<style>
  .tree-section {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    background: var(--sl-color-bg-nav);
  }

  .section-label {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    margin: 0 0 0.25rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .section-label--accent {
    font-size: 1.25rem;
    font-weight: 700;
    text-transform: none;
    letter-spacing: -0.01em;
    color: var(--sl-color-text-accent);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--sl-color-text-accent);
    opacity: 0.9;
  }

  .section-label--colored {
    color: hsl(var(--section-hue), 70%, 75%);
    border-bottom-color: hsla(var(--section-hue), 70%, 50%, 0.4);
  }

  :root[data-theme='light'] .section-label--colored {
    color: hsl(var(--section-hue), 65%, 35%);
    border-bottom-color: hsla(var(--section-hue), 60%, 40%, 0.3);
  }

  .tree-section :global(.link-list) {
    margin-top: 0;
  }
</style>
