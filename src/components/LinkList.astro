---
interface Props {
  items: { title: string; url: string | null }[];
  label?: string;
  compact?: boolean;
}
const { items, label, compact = false } = Astro.props;
---

{label && <h2 class:list={['list-label', { compact }]}>{label}</h2>}
<ul class:list={['link-list', { compact }]}>
  {items.map(item => (
    <li>
      {item.url
        ? <a href={item.url} class="link-row">
            <span>{item.title}</span>
            <span class="link-arrow" aria-hidden="true">→</span>
          </a>
        : <span class="link-row link-row--disabled">{item.title}</span>
      }
    </li>
  ))}
</ul>

<style>
  .list-label {
    font-size: 1.15rem;
    font-weight: 700;
    text-transform: none;
    letter-spacing: -0.01em;
    color: var(--sl-color-text-accent);
    margin: 0 0 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--sl-color-text-accent);
    opacity: 0.9;
  }

  .list-label.compact {
    margin-bottom: 0;
    padding-bottom: 0.1rem;
  }

  .link-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .link-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 1rem;
    font-weight: 500;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--sl-color-hairline);
    text-decoration: none;
    color: var(--sl-color-text);
    transition: all 0.2s ease;
  }

  .link-list.compact li:first-child .link-row {
    padding-top: 0;
  }

  .link-list.compact .link-row {
    padding: 0.2rem 0;
  }

  li:last-child .link-row {
    border-bottom: none;
  }

  a.link-row:hover {
    color: var(--sl-color-text-accent);
    padding-left: 0.25rem;
  }

  .link-arrow {
    color: var(--sl-color-gray-3);
    font-size: 0.85rem;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  a.link-row:hover .link-arrow {
    color: var(--sl-color-text-accent);
  }

  .link-row--disabled {
    color: var(--sl-color-gray-3);
    cursor: default;
  }
</style>
